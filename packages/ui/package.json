{
  "name": "@gbedity/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./styles.css": "./src/styles.css",
    "./*": "./src/*"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint --config ../../eslint.config.mjs 'src/**/*.{ts,tsx}'",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@dicebear/collection": "9.4.2",
    "@dicebear/core": "9.4.2",
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource/nunito": "^5.2.7",
    "@gbedity/util": "workspace:*",
    "clsx": "^2.1.1",
    "qrcode.react": "4.2.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^25.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.8.3",
    "vite": "^6.0.0",
    "vitest": "^3.0.5"
  }
}
