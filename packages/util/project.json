{
  "name": "util",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/util/src",
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "pnpm typecheck", "cwd": "packages/util" }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": { "command": "pnpm build", "cwd": "packages/util" },
      "dependsOn": ["^build"],
      "outputs": ["{projectRoot}/dist"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": { "command": "pnpm lint", "cwd": "packages/util" }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "pnpm test", "cwd": "packages/util" }
    }
  },
  "tags": ["scope:shared", "type:lib"]
}
