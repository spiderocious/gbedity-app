NODE_ENV=development
PORT=8090
LOG_LEVEL=info

APP_BASE_URL=http://localhost:8090
WEB_BASE_URL=http://localhost:5173

MONGO_URL=mongodb://127.0.0.1:27017
MONGO_DB_NAME=gbedity

REDIS_URL=redis://127.0.0.1:6379

# AI (Plead Your Case only). Placeholder key → AI degrades to "evaluation failed" gracefully.
# Drop a real key to enable. PLEAD_PROMPT_TEMPLATE* have sensible code defaults; override to tune.
OPENAI_API_KEY=sk-REPLACE_ME_placeholder
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
AI_REQUEST_TIMEOUT_MS=20000

# Admin seeding: one-shot idempotent endpoint is disabled unless this is true.
CAN_SEED_ADMIN=true

# Idle-room sweeper (reap rooms idle > 30 min). Off by default so rooms persist in dev/testing.
ROOM_SWEEP_ENABLED=false

# Auth (dev-only secrets; override in production).
JWT_SECRET=dev-only-access-secret-change-me
JWT_REFRESH_SECRET=dev-only-refresh-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
