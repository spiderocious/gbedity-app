{
  "name": "@gbedity/game",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "start": "vite preview --port 4173",
    "preview": "vite preview --port 4173",
    "typecheck": "tsc -b --noEmit",
